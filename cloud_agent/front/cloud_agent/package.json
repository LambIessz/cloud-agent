{
  "name": "cloud_agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:markdown": "node --test src/utils/markdown.test.mjs",
    "test:sse": "node --test src/utils/sseEvents.test.mjs",
    "test:scenarios": "node --test src/data/scenarios.test.mjs",
    "test:chat-stream": "node --test src/utils/chatStream.test.mjs",
    "test:sessions": "node --test src/composables/useChatSessions.test.mjs",
    "test:chat-controller": "node --test src/composables/useChatController.test.mjs",
    "test:components": "vitest run --config vitest.config.ts",
    "smoke:browser": "playwright test --config playwright.config.ts",
    "smoke:browser:real-backend": "playwright test --config playwright.real-backend.config.ts",
    "smoke:grafana": "node ../../../ops/grafana_ui_smoke.mjs",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.14.0",
    "element-plus": "^2.13.6",
    "marked": "^18.0.0",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
