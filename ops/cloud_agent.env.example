# Copy values into a local env file and pass it with:
# docker compose --env-file ops/cloud_agent.env -f ops/docker-compose.cloud-agent.yml up --build

DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY_FILE=
BASE_URL=https://api.deepseek.com
MODEL=deepseek-chat
REDIS_URL=redis://127.0.0.1:6379

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=
MYSQL_ROOT_PASSWORD_FILE=
MYSQL_DATABASE=cloud_platform
MYSQL_USER=cloud_agent
MYSQL_PASSWORD=
MYSQL_PASSWORD_FILE=

CLOUD_AGENT_MILVUS_MODE=lite
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

NEO4J_PASSWORD=
NEO4J_PASSWORD_FILE=

DASHSCOPE_API_KEY=
DASHSCOPE_API_KEY_FILE=
MILVUS_API_KEY=
MILVUS_API_KEY_FILE=
OPENWEATHER_API_KEY=
OPENWEATHER_API_KEY_FILE=
CLOUD_AGENT_AUTH_JWT_SECRET=
CLOUD_AGENT_AUTH_JWT_SECRET_FILE=
CLOUD_AGENT_METRICS_TOKEN=
CLOUD_AGENT_METRICS_TOKEN_FILE=

# Optional overrides
REDIS_TTL=1800
CLOUD_AGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CLOUD_AGENT_TOOL_TIMEOUT_SECONDS=30
CLOUD_AGENT_TOOL_RETRY_COUNT=0
CLOUD_AGENT_SEMANTIC_CACHE_ENABLED=false
CLOUD_AGENT_LONG_TERM_MEMORY_ENABLED=false
CLOUD_AGENT_VECTOR_SEARCH_ENABLED=false
CLOUD_AGENT_KNOWLEDGE_GRAPH_ENABLED=false
CLOUD_AGENT_BACKGROUND_EXTRACT_ENABLED=false
CLOUD_AGENT_SEMANTIC_CACHE_WRITE_ENABLED=false
CLOUD_AGENT_MCP_PRELOAD=false
CLOUD_AGENT_AUTH_MODE=local
CLOUD_AGENT_AUTH_STRATEGY=gateway
CLOUD_AGENT_AUTH_JWT_ALGORITHMS=HS256
CLOUD_AGENT_AUTH_OIDC_ALGORITHMS=RS256
CLOUD_AGENT_AUTH_JWT_ISSUER=
CLOUD_AGENT_AUTH_JWT_AUDIENCE=
CLOUD_AGENT_AUTH_JWT_USER_CLAIM=sub
CLOUD_AGENT_AUTH_JWT_TENANT_CLAIM=tenant_id
CLOUD_AGENT_AUTH_JWKS_URL=
CLOUD_AGENT_AUTH_OIDC_DISCOVERY_URL=
CLOUD_AGENT_AUTH_JWKS_CACHE_SECONDS=300
CLOUD_AGENT_AUTH_JWKS_TIMEOUT_SECONDS=5
CLOUD_AGENT_AUTH_JWKS_STALE_WHILE_ERROR=false
